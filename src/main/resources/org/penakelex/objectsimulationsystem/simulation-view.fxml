<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<?import org.penakelex.objectsimulationsystem.ui.IconedSection?>
<?import org.penakelex.objectsimulationsystem.ui.LabeledValueRow?>
<?import org.penakelex.objectsimulationsystem.ui.KeyActionRow?>

<HBox xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.penakelex.objectsimulationsystem.SimulationController"
      minWidth="600"
      minHeight="400"
      prefWidth="900"
      prefHeight="700"
      stylesheets="@css/main.css">

    <StackPane fx:id="simulationField"
               HBox.hgrow="ALWAYS"
               styleClass="canvas-container">

        <Canvas fx:id="simulationCanvas" styleClass="simulation-canvas"/>

        <VBox fx:id="statisticsOverlay"
              styleClass="statistics-overlay"
              visible="false"
              managed="false">

            <VBox styleClass="overlay-card">
                <HBox styleClass="overlay-title">
                    <FontIcon iconLiteral="fas-chart-bar"
                              styleClass="overlay-icon"/>
                    <Label text="%label.simulation_results"
                           styleClass="overlay-title-label"/>
                </HBox>

                <Separator styleClass="overlay-separator"/>

                <VBox styleClass="overlay-vehicles-statistics-container">
                    <LabeledValueRow fx:id="overlayTruckRow"
                                     iconLiteral="fas-truck"
                                     labelText="%label.trucks"
                                     styleClass="overlay-statistics-row"/>
                    <LabeledValueRow fx:id="overlayCarRow"
                                     iconLiteral="fas-car"
                                     labelText="%label.cars"
                                     styleClass="overlay-statistics-row"/>
                    <LabeledValueRow fx:id="overlayTotalRow"
                                     iconLiteral="fas-chart-line"
                                     labelText="%label.total"
                                     styleClass="overlay-statistics-row"/>
                </VBox>

                <Separator styleClass="overlay-separator"/>

                <HBox styleClass="overlay-time-row">
                    <FontIcon iconLiteral="fas-clock"
                              styleClass="overlay-time-icon"/>
                    <Label fx:id="overlayTimeLabel"
                           styleClass="overlay-time-label"/>
                </HBox>
            </VBox>
        </VBox>
    </StackPane>

    <VBox styleClass="control-panel" HBox.hgrow="NEVER">
        <ScrollPane styleClass="control-panel-scroll"
                    VBox.vgrow="ALWAYS">

            <VBox styleClass="control-panel-content">
                <IconedSection iconLiteral="fas-cogs"
                               title="%label.generation.parameters">
                    <IconedSection iconLiteral="fas-truck"
                                   title="%label.trucks"
                                   styleClass="truck-parameters-section">
                        <LabeledValueRow fx:id="truckPeriodRow"
                                         iconLiteral="fas-clock"
                                         labelText="%label.generation.period"
                                         styleClass="period-row"/>
                        <LabeledValueRow fx:id="truckProbabilityRow"
                                         iconLiteral="fas-percentage"
                                         labelText="%label.generation.probability"
                                         styleClass="probability-row"/>
                    </IconedSection>

                    <IconedSection iconLiteral="fas-car"
                                   title="%label.cars"
                                   styleClass="car-parameters-section">
                        <LabeledValueRow fx:id="carPeriodRow"
                                         iconLiteral="fas-clock"
                                         labelText="%label.generation.period"
                                         styleClass="period-row"/>
                        <LabeledValueRow fx:id="carProbabilityRow"
                                         iconLiteral="fas-percentage"
                                         labelText="%label.generation.probability"
                                         styleClass="probability-row"/>
                    </IconedSection>
                </IconedSection>

                <Separator styleClass="section-separator"/>

                <VBox fx:id="infoContainer" styleClass="info-container">
                    <VBox fx:id="timeContainer" styleClass="time-container">
                        <IconedSection iconLiteral="fas-clock"
                                       title="%label.simulation.time">
                            <Label fx:id="timeLabel" styleClass="time-value"/>
                        </IconedSection>

                        <Separator styleClass="section-separator"/>
                    </VBox>

                    <IconedSection iconLiteral="fas-chart-bar"
                                   title="%label.statistics.title">
                        <LabeledValueRow fx:id="truckRow"
                                         iconLiteral="fas-truck"
                                         labelText="%label.trucks"
                                         styleClass="truck-parameters-row"/>
                        <LabeledValueRow fx:id="carRow"
                                         iconLiteral="fas-car"
                                         labelText="%label.cars"
                                         styleClass="car-parameters-row"/>
                        <LabeledValueRow fx:id="totalRow"
                                         iconLiteral="fas-chart-line"
                                         labelText="%label.total"
                                         styleClass="total-vehicles-parameters-row"/>
                    </IconedSection>

                    <Separator styleClass="section-separator"/>
                </VBox>

                <IconedSection iconLiteral="fas-cog"
                               title="%label.controls.title">
                    <KeyActionRow keyBind="%label.controls.keybind.start"
                                  actionText="%label.controls.start"/>
                    <KeyActionRow keyBind="%label.controls.keybind.stop"
                                  actionText="%label.controls.stop"/>
                    <KeyActionRow keyBind="%label.controls.keybind.time"
                                  actionText="%label.controls.time"/>
                    <KeyActionRow keyBind="%label.controls.keybind.restart"
                                  actionText="%label.controls.restart"/>
                </IconedSection>
            </VBox>
        </ScrollPane>

        <VBox styleClass="status-section">
            <HBox styleClass="status-container">
                <FontIcon fx:id="statusIcon"
                          iconLiteral="fas-pause-circle"
                          styleClass="status-icon"/>
                <Label fx:id="statusLabel"
                       text="%label.status.stopped"
                       styleClass="status-value stopped"/>
            </HBox>
        </VBox>
    </VBox>
</HBox>